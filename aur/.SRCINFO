pkgbase = reconninja
	pkgdesc = Autonomous multi-phase security reconnaissance framework
	pkgver = 10.2.0
	pkgrel = 1
	url = https://github.com/ExploitCraft/ReconNinja
	arch = any
	license = MIT
	makedepends = python-build
	makedepends = python-installer
	makedepends = python-wheel
	makedepends = python-setuptools
	makedepends = python-setuptools-scm
	makedepends = python-pytest
	depends = python>=3.10
	depends = python-rich
	depends = python-dotenv
	depends = python-requests
	depends = python-dnspython
	depends = python-beautifulsoup4
	depends = python-cryptography
	depends = python-yaml
	depends = python-ldap3
	depends = python-whois
	depends = python-ipwhois
	depends = python-flask
	optdepends = python-groq: --ai-provider groq
	optdepends = python-openai: --ai-provider openai
	optdepends = python-google-generativeai: --ai-provider gemini
	optdepends = python-shodan: --shodan flag
	optdepends = python-pymongo: MongoDB deep exposure check
	optdepends = python-pysnmp: full SNMP MIB walk
	optdepends = python-weasyprint: preferred PDF backend
	optdepends = python-fpdf2: fallback PDF backend
	optdepends = python-impacket: --ad-recon (Kerberoasting / AS-REP)
	optdepends = python-bloodhound-python: --ad-recon (BloodHound collector)
	optdepends = python-neo4j: --graph-export neo4j
	optdepends = python-prometheus-client: --metrics-port N
	optdepends = python-opentelemetry-api: --otlp-endpoint URL
	optdepends = python-textual: Textual TUI (otherwise --no-tui is implicit)
	optdepends = nmap: core port scan + service fingerprint
	optdepends = masscan: high-speed port scan (--masscan, requires root)
	optdepends = rustscan: fast port discovery before nmap (--rustscan)
	optdepends = subfinder: subdomain enumeration (--subdomains)
	optdepends = amass: subdomain enumeration (--subdomains)
	optdepends = assetfinder: subdomain enumeration (--subdomains)
	optdepends = httpx-bin: HTTP probing + tech fingerprint (--httpx)
	optdepends = whatweb: web tech identification (--whatweb)
	optdepends = nikto: web server vuln scanner (--nikto)
	optdepends = feroxbuster: recursive directory brute-force (--feroxbuster)
	optdepends = ffuf: directory brute-force fallback
	optdepends = dirsearch: directory brute-force fallback
	optdepends = gobuster: directory brute-force fallback
	optdepends = sqlmap: SQLi testing (external)
	optdepends = wfuzz: web fuzzing (external)
	optdepends = nuclei: template-based vuln scanner (--nuclei)
	optdepends = aquatone: web screenshots (--aquatone)
	optdepends = gowitness: web screenshots (--gowitness)
	optdepends = wafw00f: WAF detection (--waf)
	optdepends = bind-tools: dig / nslookup for DNS zone transfer check
	optdepends = dnsx: DNS resolver
	optdepends = whois: WHOIS CLI (python-whois fallback if missing)
	optdepends = seclists: wordlists for directory brute-force
	optdepends = net-tools: legacy network utilities
	optdepends = curl: HTTP probe fallback
	optdepends = gpg: evidence signing (--evidence-sign-key)
	source = reconninja::git+https://github.com/ExploitCraft/ReconNinja.git#tag=v10.2.0
	sha256sums = SKIP

pkgname = reconninja
